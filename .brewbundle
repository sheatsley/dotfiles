tap "homebrew/bundle"
tap "homebrew/cask"
tap "homebrew/cask-drivers"
tap "homebrew/cask-fonts"
tap "homebrew/core"
tap "homebrew/services"
tap "sheatsley/sheatsley"
# Official Amazon AWS command-line interface
brew "awscli"
# Formatting tools for C, C++, Obj-C, Java, JavaScript, TypeScript
brew "clang-format"
# Cross-platform make
brew "cmake"
# Distributed revision control system
brew "git"
# Enable transparent encryption/decryption of files in a git repo
brew "git-crypt"
# GNU Pretty Good Privacy (PGP) package
brew "gnupg", link: false
# Open source programming language to build simple/reliable/efficient software
brew "go"
# Command-line tools for OpenPGP-related operations
brew "hopenpgp-tools"
# Configurable static site generator
brew "hugo"
# LastPass command-line interface tool
brew "lastpass-cli"
# Compare and mark up LaTeX file differences
brew "latexdiff"
# GUI for vim, made for macOS
brew "macvim"
# Mac App Store command-line interface
brew "mas"
# Platform built on V8 to build network applications
brew "node"
# Open client for Cisco AnyConnect VPN
brew "openconnect"
# Outputs current CPU temperature for OSX
brew "osx-cpu-temp"
# 7-Zip (high compression file archiver) implementation
brew "p7zip"
# Pinentry for GPG on Mac
brew "pinentry-mac"
# Safe, concurrent, practical language
brew "rust"
# Yet Another Dotfiles Manager
brew "yadm"
# Tool for managing your YubiKey configuration
brew "ykman"
# YubiKey personalization library and tool
brew "ykpers"
# UNIX shell (command interpreter)
brew "zsh"
# A command-line interface thesaurus
brew "sheatsley/sheatsley/cli-thesaurus"
# Client for the Box cloud storage service
cask "box-drive"
cask "camtasia"
# Voice and text chat software
cask "discord"
# App to build and share containerized applications and microservices
cask "docker"
# Web browser
cask "firefox"
cask "font-dejavu-sans-mono-for-powerline"
cask "google-backup-and-sync"
# Tools to protect your emails and files
cask "gpg-suite"
# Terminal emulator as alternative to Apple's Terminal app
cask "iterm2"
# Password manager
cask "lastpass"
# Full TeX Live distribution without GUI applications
cask "mactex-no-gui"
cask "microsoft-office"
# Open source implementation of Microsoft's .NET Framework
cask "mono-mdk"
# Video chat, voice call and instant messaging application
cask "skype"
# Team communication and collaboration software
cask "slack"
# Music streaming service
cask "spotify"
# App to run other operating systems without rebooting
cask "vmware-fusion"
cask "webex-meetings"
# Open-source version of the X.Org X Window System
cask "xquartz"
# Application for configuring any YubiKey
cask "yubico-yubikey-manager"
# Video communication and virtual meeting platform
cask "zoom"
# Collect, organize, cite, and share research sources
cask "zotero"
mas "Adblock Plus", id: 1432731683
