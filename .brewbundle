tap "homebrew/bundle"
tap "homebrew/cask-fonts"
tap "homebrew/services"
tap "sheatsley/formulae"
tap "smudge/smudge"
tap "tsung-ju/iguanatexmac"
tap "universal-ctags/universal-ctags"
# Clone of cat(1) with syntax highlighting and Git integration
brew "bat"
# Interpreted, interactive, object-oriented programming language
brew "python@3.11"
# Create and view interactive cheat sheets for *nix commands
brew "cheat"
# Formatting tools for C, C++, Obj-C, Java, JavaScript, TypeScript
brew "clang-format"
# Cross-platform make
brew "cmake"
# Distributed revision control system
brew "git"
# Enable transparent encryption/decryption of files in a git repo
brew "git-crypt"
# Git extension for versioning large files
brew "git-lfs"
# GNU Pretty Good Privacy (PGP) package
brew "gnupg"
# Open source programming language to build simple/reliable/efficient software
brew "go"
# Command-line tools for OpenPGP-related operations
brew "hopenpgp-tools"
# Configurable static site generator
brew "hugo"
# Update of iperf: measures TCP, UDP, and SCTP bandwidth
brew "iperf3"
# Compare and mark up LaTeX file differences
brew "latexdiff"
# Mac App Store command-line interface
brew "mas"
# Platform built on V8 to build network applications
brew "node"
# 7-Zip (high compression file archiver) implementation
brew "p7zip"
# Port of pdftk in java
brew "pdftk-java"
# Pinentry for GPG on Mac
brew "pinentry-mac"
# Search tool like grep and The Silver Searcher
brew "ripgrep"
# Safe, concurrent, practical language
brew "rust"
# Yet Another Dotfiles Manager
brew "yadm"
# Tool for managing your YubiKey configuration
brew "ykman"
# YubiKey personalization library and tool
brew "ykpers"
# UNIX shell (command interpreter)
brew "zsh"
# A command-line interface thesaurus
brew "sheatsley/formulae/cli-thesaurus"
# Maintained ctags implementation
brew "universal-ctags/universal-ctags/universal-ctags", args: ["HEAD"]
# Electronics prototyping platform
cask "arduino"
# Virtual Audio Driver
cask "blackhole-2ch"
# Voice and text chat software
cask "discord"
# App to build and share containerized applications and microservices
cask "docker"
# Elgato FACECAM configuration tool
cask "elgato-camera-hub"
# Web browser
cask "firefox"
# Developer targeted fonts with a high number of glyphs
cask "font-dejavu-sans-mono-nerd-font"
cask "iguanatexmac"
# Terminal emulator as alternative to Apple's Terminal app
cask "iterm2"
cask "latexit-metadata"
# Full TeX Live distribution without GUI applications
cask "mactex-no-gui"
# Provides updates to various Microsoft products
cask "microsoft-auto-update"
# Office suite
cask "microsoft-office"
# Remote desktop client
cask "microsoft-remote-desktop"
# Meet, chat, call, and collaborate in just one place
cask "microsoft-teams"
# GameStream client
cask "moonlight"
# Lightpack and Prismatik open repository
cask "psieg-prismatik"
# Instant messaging application focusing on security
cask "signal"
# Team communication and collaboration software
cask "slack"
# Music streaming service
cask "spotify"
# Data visualization software
cask "tableau"
# Combine, shape, and clean your data for analysis
cask "tableau-prep"
# Create, manage, and run virtual machines
cask "vmware-fusion"
# Application for configuring any YubiKey
cask "yubico-yubikey-manager"
# Video communication and virtual meeting platform
cask "zoom"
# Collect, organize, cite, and share research sources
cask "zotero"
