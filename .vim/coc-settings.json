{
    "coc.preferences.formatOnSave": true,
    "diagnostic.errorSign": "\uea87",
    "diagnostic.hintSign": "\uf0eb",
    "diagnostic.warningSign": "\uf071",
    "explorer.buffer.root.template": "[icon & 1] Buffers",
    "explorer.file.cdCommand": "tcd",
    "explorer.file.root.template": "[icon & 1] Files ([root]) [fullpath]",
    "explorer.file.reveal.auto": true,
    "explorer.focus": false,
    "explorer.icon.enableNerdfont": true,
    "explorer.keyMappings.global": {
        "<C-S>": "open:split",
        "<C-T>": "open:tab",
        "<C-V>": "open:vsplit"
    },
    "explorer.sources": [
        {
            "name": "buffer",
            "expand": true
        },
        {
            "name": "file",
            "expand": true
        }
    ],
    "explorer.width": 30,
    "pyright.disableCompletion": true,
    "pyright.inlayHints.functionReturnTypes": false,
    "pyright.inlayHints.variableTypes": false,
    "python.analysis.typeCheckingMode": "off",
    "python.formatting.provider": "black",
    "python.linting.flake8Args": [
        "--max-line-length=88",
        "--extend-ignore=E203"
    ],
    "python.linting.flake8Enabled": true,
    "suggest.noselect": true,
    "suggest.completionItemKindLabels": {
        "class": "\uea8c",
        "color": "\ue22b",
        "constant": "\uf8fe",
        "default": "\uf29c",
        "enum": "\uf435",
        "enumMember": "\uf02b",
        "event": "\ufacd",
        "field": "\uf9be",
        "file": "\uf723",
        "folder": "\uf114",
        "function": "\u0192",
        "interface": "\uf417",
        "keyword": "\uf1de",
        "method": "\uf09a",
        "module": "\uf40d",
        "operator": "\u03a8",
        "property": "\uf0e8",
        "reference": "\ufa46",
        "snippet": "\ue60b",
        "struct": "\ufb44",
        "text": "\ue612",
        "typeParameter": "\uf728",
        "unit": "\uf475",
        "value": "\uf89f",
        "variable": "\ue624",
    }
}
